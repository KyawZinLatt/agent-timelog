{
  "hooks": {
    "Stop": [
      { "hooks": [ { "type": "command", "command": "python3 \"$HOME/.claude/hooks/timelog/claude_hook.py\"" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "python3 \"$HOME/.claude/hooks/timelog/claude_hook.py\"" } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "python3 \"$HOME/.claude/hooks/timelog/claude_hook.py\"" } ] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "python3 \"$HOME/.claude/hooks/timelog/remind_hook.py\"", "timeout": 10 } ] }
    ]
  }
}
